<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light theme. AccentBrush, ItemHoverBackground and ItemActiveBackground are replaced at runtime
         by ThemeService from the live Windows accent color. -->

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/MultiDesk;component/Themes/Controls.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <SolidColorBrush x:Key="SidebarBackground"        Color="#FFF3F3F3" />
    <SolidColorBrush x:Key="TextPrimary"              Color="#FF1A1A1A" />
    <SolidColorBrush x:Key="TextSecondary"            Color="#FF6A6A6A" />
    <SolidColorBrush x:Key="TitleText"                Color="#FF333333" />
    <SolidColorBrush x:Key="SeparatorColor"           Color="#FFD0D0D0" />
    <SolidColorBrush x:Key="ChevronColor"             Color="#FF707070" />
    <SolidColorBrush x:Key="TextBoxBackground"        Color="#FFFFFFFF" />

    <SolidColorBrush x:Key="SectionBackground"        Color="#00000000" />
    <SolidColorBrush x:Key="SectionActiveBackground"  Color="#14000000" />
    <SolidColorBrush x:Key="SectionActiveBorder"      Color="#FF9A9A9A" />
    <SolidColorBrush x:Key="TileHoverBackground"      Color="#14000000" />

    <SolidColorBrush x:Key="AccentBrush"          Color="#FF0078D4" />
    <SolidColorBrush x:Key="ItemHoverBackground"  Color="#260078D4" />
    <SolidColorBrush x:Key="ItemActiveBackground" Color="#400078D4" />

</ResourceDictionary>
