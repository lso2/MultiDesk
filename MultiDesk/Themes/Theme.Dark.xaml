<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark theme. AccentBrush, ItemHoverBackground and ItemActiveBackground are replaced at runtime
         by ThemeService from the live Windows accent color. -->

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/MultiDesk;component/Themes/Controls.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <SolidColorBrush x:Key="SidebarBackground"        Color="#FF1E1E1E" />
    <SolidColorBrush x:Key="TextPrimary"              Color="#FFEDEDED" />
    <SolidColorBrush x:Key="TextSecondary"            Color="#FF9B9B9B" />
    <SolidColorBrush x:Key="TitleText"                Color="#FFD0D0D0" />
    <SolidColorBrush x:Key="SeparatorColor"           Color="#FF3A3A3A" />
    <SolidColorBrush x:Key="ChevronColor"             Color="#FF8A8A8A" />
    <SolidColorBrush x:Key="TextBoxBackground"        Color="#FF2A2A2A" />

    <SolidColorBrush x:Key="SectionBackground"        Color="#00000000" />
    <SolidColorBrush x:Key="SectionActiveBackground"  Color="#14FFFFFF" />
    <SolidColorBrush x:Key="SectionActiveBorder"      Color="#FF6E6E6E" />
    <SolidColorBrush x:Key="TileHoverBackground"      Color="#1AFFFFFF" />

    <SolidColorBrush x:Key="AccentBrush"          Color="#FF0078D4" />
    <SolidColorBrush x:Key="ItemHoverBackground"  Color="#260078D4" />
    <SolidColorBrush x:Key="ItemActiveBackground" Color="#400078D4" />

</ResourceDictionary>
