<Window x:Class="MultiDesk.UI.SwitcherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MultiDesk Switcher" WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen" Width="540" Height="440" AllowsTransparency="False"
        Topmost="True" Background="{DynamicResource SidebarBackground}">
    <Window.Resources>
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="5" Padding="8,6" Margin="0,1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ItemHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ItemActiveBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource SeparatorColor}" BorderThickness="1">
        <DockPanel Margin="10">
            <TextBlock DockPanel.Dock="Top" Text="Switch window" FontSize="14" FontWeight="SemiBold"
                       Margin="4,2,4,8" Foreground="{DynamicResource TextPrimary}" />
            <ListBox x:Name="List" Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{Binding Icon}" Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Title}" Margin="10,0,0,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis" MaxWidth="360" />
                            <TextBlock Text="{Binding Desktop}" Margin="10,0,0,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="11" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
</Window>
