<Window x:Class="MultiDesk.UI.PreviewPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False"
        ShowActivated="False" Topmost="True" AllowsTransparency="False"
        Focusable="False" IsHitTestVisible="False"
        Width="300" Height="212"
        Background="{DynamicResource SidebarBackground}">
    <Border BorderBrush="{DynamicResource SeparatorColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Height="30" Background="{DynamicResource SectionActiveBackground}">
                <TextBlock x:Name="TitleText" Margin="10,0" VerticalAlignment="Center" FontSize="13"
                           FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource TextPrimary}" />
            </Border>
            <Grid Grid.Row="1" Margin="8,0,8,8">
                <Image x:Name="CachedPreview" Stretch="Uniform" Visibility="Collapsed"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                <Image x:Name="IconFallback" Width="72" Height="72" Stretch="Uniform"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" />
            </Grid>
        </Grid>
    </Border>
</Window>
